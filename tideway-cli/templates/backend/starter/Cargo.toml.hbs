[package]
name = "{{project_name}}"
version = "0.1.0"
edition = "2021"

[dependencies]
tideway = { version = "{{tideway_version}}"{{#if has_tideway_features}}, features = [{{#each tideway_features}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]{{/if}} }
tokio = { version = "1.48", features = ["full"] }
axum = "0.8"
{{#if has_auth_feature}}
async-trait = "0.1"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
{{/if}}
{{#if has_database_feature}}
sea-orm = { version = "1.1", features = ["{{#if is_sqlite_database}}sqlx-sqlite{{else}}sqlx-postgres{{/if}}", "runtime-tokio-rustls"] }
{{/if}}
{{#if has_openapi_feature}}
utoipa = { version = "5", features = ["axum_extras"] }
{{/if}}
