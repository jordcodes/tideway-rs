// Handlers

fn user_store(state: &AuthState) -> DbUserStore {
    let store = DbUserStore::new(state.db.clone());
    match state.email_service.clone() {
        Some(email_service) => store.with_email_service(email_service),
        None => store,
    }
}

enum AuthRouteError {
    Tideway(tideway::TidewayError),
    RateLimited { message: String, retry_after: u64 },
}

impl From<tideway::TidewayError> for AuthRouteError {
    fn from(error: tideway::TidewayError) -> Self {
        Self::Tideway(error)
    }
}

impl IntoResponse for AuthRouteError {
    fn into_response(self) -> Response {
        match self {
            Self::Tideway(error) => error.into_response(),
            Self::RateLimited {
                message,
                retry_after,
            } => {
                let mut response = tideway::TidewayError::TooManyRequests(message).into_response();
                response.headers_mut().insert(
                    RETRY_AFTER,
                    HeaderValue::from_str(&retry_after.to_string())
                        .expect("retry-after seconds are a valid header value"),
                );
                response
            }
        }
    }
}

type AuthRouteResult<T> = std::result::Result<T, AuthRouteError>;

fn check_email_rate_limit(
    state: &AuthState,
    address: SocketAddr,
    headers: &HeaderMap,
    email: &str,
) -> AuthRouteResult<()> {
    let client_ip = state.client_ip_resolver.resolve(address.ip(), headers);
    for key in [
        format!("ip:{client_ip}"),
        format!("email:{}", email.trim().to_ascii_lowercase()),
    ] {
        if let Err(retry_after) = state.email_rate_limiter.check(&key) {
            return Err(AuthRouteError::RateLimited {
                message: "Too many email requests; try again later".to_string(),
                retry_after,
            });
        }
    }
    Ok(())
}

fn enforce_auth_rate_limit(
    state: &AuthState,
    limiter: &AuthRateLimiter,
    endpoint: &'static str,
    address: SocketAddr,
    headers: &HeaderMap,
) -> AuthRouteResult<()> {
    let client_ip = state.client_ip_resolver.resolve(address.ip(), headers);
    if let Err(retry_after) = limiter.check(&client_ip.to_string()) {
        tracing::warn!(
            target: "auth.endpoint.rate_limited",
            endpoint,
            ip = %client_ip,
            retry_after_secs = retry_after,
            "Authentication endpoint rate limited"
        );
        return Err(AuthRouteError::RateLimited {
            message: format!(
                "Too many {endpoint} attempts. Please try again in {retry_after} seconds."
            ),
            retry_after,
        });
    }
    Ok(())
}

async fn register(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<RegisterBody>,
) -> AuthRouteResult<Json<RegisterResponse>> {
    enforce_auth_rate_limit(
        &state,
        &state.registration_rate_limiter,
        "registration",
        address,
        &headers,
    )?;
    {{#if has_organizations}}
    let transaction = Arc::new(
        state
            .db
            .begin()
            .await
            .map_err(|e| tideway::TidewayError::Database(e.to_string()))?,
    );
    let user_store = DbUserStore::from_transaction(transaction.clone());
    let user_store = match state.email_service.clone() {
        Some(email_service) => user_store.with_email_service(email_service),
        None => user_store,
    };
    {{else}}
    let user_store = user_store(&state);
    {{/if}}

    let flow = RegistrationFlow::new(user_store);
    let request = RegisterRequest {
        email: body.email.clone(),
        password: body.password,
        name: body.name,
    };

    let user = flow.register(request).await?;
    drop(flow);
    let user_id = user.id;

    {{#if has_organizations}}
    // Generate organization ID and slug
    let org_id = format!(
        "org_{}",
        Uuid::new_v4().to_string().replace("-", "")[..12].to_string()
    );
    let slug = generate_slug(&body.organization_name);
    let now = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .map(|d| d.as_secs() as i64)
        .unwrap_or(0);

    // Create the organization
    let org = organization::ActiveModel {
        id: Set(org_id.clone()),
        name: Set(body.organization_name),
        slug: Set(slug),
        owner_id: Set(user_id),
        contact_email: Set(body.email.clone()),
        created_at: Set(now),
        updated_at: Set(now),
    };

    org.insert(transaction.as_ref())
        .await
        .map_err(|e| tideway::TidewayError::Database(e.to_string()))?;

    // Create membership
    let organization_member = organization_member::ActiveModel {
        organization_id: Set(org_id.clone()),
        user_id: Set(user_id),
        role: Set("owner".to_string()),
        joined_at: Set(now),
    };

    organization_member
        .insert(transaction.as_ref())
        .await
        .map_err(|e| tideway::TidewayError::Database(e.to_string()))?;

    Arc::try_unwrap(transaction)
        .map_err(|_| tideway::TidewayError::internal("Registration transaction still in use"))?
        .commit()
        .await
        .map_err(|e| tideway::TidewayError::Database(e.to_string()))?;

    send_registration_verification(&state, &user_id.to_string(), &body.email).await;

    Ok(Json(RegisterResponse {
        success: true,
        message: "Registration successful.".into(),
        user_id: user_id.to_string(),
        organization_id: org_id,
    }))
    {{else}}
    send_registration_verification(&state, &user_id.to_string(), &body.email).await;

    Ok(Json(RegisterResponse {
        success: true,
        message: "Registration successful.".into(),
        user_id: user_id.to_string(),
    }))
    {{/if}}
}

async fn send_registration_verification(state: &AuthState, user_id: &str, email: &str) {
    if !state.require_email_verification {
        return;
    }

    let flow = EmailVerificationFlow::new(user_store(state));
    if let Err(error) = flow.send_verification(user_id, email).await {
        tracing::error!(user_id, %error, "Failed to send registration verification email");
    }
}

{{#if has_organizations}}
fn generate_slug(name: &str) -> String {
    let base_slug: String = name
        .to_lowercase()
        .chars()
        .map(|c| if c.is_alphanumeric() { c } else { '-' })
        .collect::<String>()
        .split('-')
        .filter(|s| !s.is_empty())
        .collect::<Vec<_>>()
        .join("-");

    let suffix = &Uuid::new_v4().to_string()[..8];
    format!("{}-{}", base_slug, suffix)
}
{{/if}}

async fn login(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<LoginBody>,
) -> Result<LoginHttpResponse> {
    let user_store = user_store(&state);
    let token_issuer = AppTokenIssuer::new(state.jwt_issuer.clone());
    let token_store = DbRefreshTokenStore::new(state.db.clone());

    let flow = LoginFlow::new(
        user_store,
        state.mfa_tokens.clone(),
        token_issuer,
        LoginFlowConfig::new(&state.app_name)
            .require_verification(state.require_email_verification),
    )
    .with_refresh_store(token_store)
    .with_rate_limiter(state.login_rate_limiter.clone());

    let request = LoginRequest {
        email: body.email,
        password: body.password,
        remember_me: body.remember_me.unwrap_or(false),
        mfa_code: body.mfa_code,
    };

    let response = flow
        .login_with_ip(
            request,
            Some(state.client_ip_resolver.resolve(address.ip(), &headers).to_string()),
        )
        .await?;
    Ok(response.into())
}

async fn logout(
    Extension(state): Extension<AuthState>,
    Json(body): Json<LogoutBody>,
) -> Result<MessageResponse> {
    let token_store = DbRefreshTokenStore::new(state.db.clone());
    let user_store = user_store(&state);

    let refresh_flow = tideway::auth::TokenRefreshFlow::new(
        state.jwt_issuer.as_ref().clone(),
        token_store,
        user_store,
        state.jwt_secret.as_bytes(),
    );

    refresh_flow.revoke(&body.refresh_token).await?;

    Ok(MessageResponse::success("Logged out successfully"))
}

async fn refresh(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<RefreshBody>,
) -> AuthRouteResult<Json<RefreshResponse>> {
    enforce_auth_rate_limit(
        &state,
        &state.refresh_rate_limiter,
        "refresh",
        address,
        &headers,
    )?;
    let token_store = DbRefreshTokenStore::new(state.db.clone());
    let user_store = user_store(&state);

    let refresh_flow = tideway::auth::TokenRefreshFlow::new(
        state.jwt_issuer.as_ref().clone(),
        token_store,
        user_store,
        state.jwt_secret.as_bytes(),
    );

    let token_pair = refresh_flow.refresh(&body.refresh_token).await?;

    Ok(Json(RefreshResponse {
        access_token: token_pair.access_token,
        refresh_token: token_pair.refresh_token,
        expires_in: token_pair.expires_in,
        token_type: "Bearer",
    }))
}

async fn request_password_reset(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<PasswordResetBody>,
) -> AuthRouteResult<MessageResponse> {
    check_email_rate_limit(&state, address, &headers, &body.email)?;
    let user_store = user_store(&state);

    let flow = PasswordResetFlow::new(user_store);
    let request = PasswordResetRequest { email: body.email };

    if let Err(error) = flow.request_reset(request).await {
        tracing::error!(%error, "Password reset request failed");
    }

    Ok(MessageResponse::success(
        "If an account with that email exists, a password reset link has been sent.",
    ))
}

async fn complete_password_reset(
    Extension(state): Extension<AuthState>,
    Json(body): Json<PasswordResetCompleteBody>,
) -> Result<MessageResponse> {
    let user_store = user_store(&state);

    let flow = PasswordResetFlow::new(user_store);
    let request = PasswordResetComplete {
        token: body.token,
        new_password: body.new_password,
    };

    flow.complete_reset(request).await?;

    Ok(MessageResponse::success("Password has been reset successfully."))
}

async fn verify_email(
    Extension(state): Extension<AuthState>,
    Json(body): Json<VerifyEmailBody>,
) -> Result<MessageResponse> {
    EmailVerificationFlow::new(user_store(&state))
        .verify(EmailVerifyRequest { token: body.token })
        .await?;
    Ok(MessageResponse::success("Email verified successfully."))
}

async fn resend_verification(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<ResendVerificationBody>,
) -> AuthRouteResult<MessageResponse> {
    let normalized_email = body.email.trim().to_ascii_lowercase();
    check_email_rate_limit(&state, address, &headers, &normalized_email)?;
    let store = user_store(&state);

    // Preserve the same response for unknown and already-verified accounts to
    // avoid exposing registration state.
    if let Ok(Some(user)) = store.find_by_email(&normalized_email).await {
        if user.email_verified_at.is_none() {
            let flow = EmailVerificationFlow::new(store);
            if let Err(error) = flow
                .resend(
                    ResendVerificationRequest {
                        email: normalized_email,
                    },
                    &user.id.to_string(),
                )
                .await
            {
                tracing::error!(user_id = %user.id, %error, "Verification resend failed");
            }
        }
    }

    Ok(MessageResponse::success(
        "If an unverified account with that email exists, a verification link has been sent.",
    ))
}

{{#if has_auth_mfa_feature}}
async fn verify_mfa(
    Extension(state): Extension<AuthState>,
    Json(body): Json<MfaVerifyBody>,
) -> Result<LoginHttpResponse> {
    let user_store = user_store(&state);
    let token_issuer = AppTokenIssuer::new(state.jwt_issuer.clone());
    let token_store = DbRefreshTokenStore::new(state.db.clone());

    let flow = LoginFlow::new(
        user_store,
        state.mfa_tokens.clone(),
        token_issuer,
        LoginFlowConfig::new(&state.app_name)
            .require_verification(state.require_email_verification),
    )
    .with_refresh_store(token_store);

    let request = tideway::auth::MfaVerifyRequest {
        mfa_token: body.mfa_token,
        code: body.code,
    };

    let response = flow.verify_mfa(request).await?;
    Ok(response.into())
}
{{/if}}
