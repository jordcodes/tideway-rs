use tideway::{Config, ConfigBuilder};

/// App configuration loaded from environment variables.
pub struct AppConfig {
    pub tideway: Config,
    pub database_url: Option<String>,
    pub jwt_secret: Option<String>,
    pub jwt_issuer: String,
    pub jwt_audience: String,
}

impl AppConfig {
    pub fn from_env() -> Self {
        let tideway = ConfigBuilder::new()
            .from_env()
            .build()
            .expect("Invalid TIDEWAY_* config");

        Self {
            tideway,
            database_url: std::env::var("DATABASE_URL").ok(),
            jwt_secret: std::env::var("JWT_SECRET").ok(),
            jwt_issuer: std::env::var("JWT_ISSUER").unwrap_or_else(|_| env!("CARGO_PKG_NAME").into()),
            jwt_audience: std::env::var("JWT_AUDIENCE").unwrap_or_else(|_| env!("CARGO_PKG_NAME").into()),
        }
    }
}
