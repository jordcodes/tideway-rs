//! Database-backed stores for the generated authentication flow.

use async_trait::async_trait;
use chrono::{Duration, Utc};
use sea_orm::{
    sea_query::Expr, ActiveModelTrait, ColumnTrait, DatabaseConnection, EntityTrait, QueryFilter,
    Set,
};
{{#if has_auth_mfa_feature}}
use sea_orm::{Condition, PaginatorTrait, QueryOrder, TransactionTrait};
{{/if}}
use std::{
    sync::{Arc, atomic::{AtomicI64, Ordering}},
    time::SystemTime,
};
use tideway::auth::{
    JwtIssuer, MfaTokenStore, PasswordResetStore, RefreshTokenStore, TokenIssuer, UserCreator,
    UserLoader, UserStore,
};
{{#if has_auth_mfa_feature}}
use tideway::auth::{BackupCodeGenerator, MfaSecretCipher};
{{/if}}
use tideway::{Result, TidewayError};
use uuid::Uuid;

use crate::entities::{auth_token, refresh_token_family, user};
{{#if has_auth_mfa_feature}}
use crate::entities::mfa_backup_code;
{{/if}}

#[derive(Clone)]
pub struct DbUserStore {
    db: Arc<DatabaseConnection>,
    require_email_verification: bool,
    {{#if has_auth_mfa_feature}}
    mfa_cipher: Arc<MfaSecretCipher>,
    {{/if}}
}

impl DbUserStore {
    pub fn new(
        db: Arc<DatabaseConnection>,
        require_email_verification: bool,
        {{#if has_auth_mfa_feature}}
        mfa_cipher: Arc<MfaSecretCipher>,
        {{/if}}
    ) -> Self {
        Self {
            db,
            require_email_verification,
            {{#if has_auth_mfa_feature}}
            mfa_cipher,
            {{/if}}
        }
    }

    fn parse_user_id(id: &str) -> Result<Uuid> {
        Uuid::parse_str(id).map_err(|_| TidewayError::bad_request("Invalid user ID"))
    }

    {{#if has_auth_mfa_feature}}
    /// Persist verified TOTP enrollment and a fresh set of plaintext backup codes.
    ///
    /// Call this only after verifying a TOTP code against `totp_secret`. The
    /// secret is encrypted and backup codes are Argon2id-hashed before the
    /// transaction writes any MFA state.
    pub async fn enable_mfa(
        &self,
        user_id: Uuid,
        totp_secret: &str,
        backup_codes: &[String],
    ) -> Result<()> {
        if backup_codes.is_empty() {
            return Err(TidewayError::bad_request("At least one MFA backup code is required"));
        }
        let encrypted = self.mfa_cipher.encrypt(&user_id.to_string(), totp_secret)?;
        let mut hashes = Vec::with_capacity(backup_codes.len());
        for code in backup_codes {
            hashes.push(BackupCodeGenerator::hash(code).await?);
        }

        let transaction = self
            .db
            .begin()
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        let updated = user::Entity::update_many()
            .col_expr(user::Column::MfaEnabled, Expr::value(true))
            .col_expr(
                user::Column::MfaTotpSecretEncrypted,
                Expr::value(Some(encrypted)),
            )
            .col_expr(
                user::Column::MfaLastTotpStep,
                Expr::value(Option::<i64>::None),
            )
            .col_expr(user::Column::FailedMfaAttempts, Expr::value(0))
            .col_expr(user::Column::UpdatedAt, Expr::value(Utc::now()))
            .filter(user::Column::Id.eq(user_id))
            .filter(user::Column::MfaEnabled.eq(false))
            .exec(&transaction)
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        if updated.rows_affected != 1 {
            return Err(TidewayError::bad_request("MFA is already enabled or the user does not exist"));
        }
        mfa_backup_code::Entity::delete_many()
            .filter(mfa_backup_code::Column::UserId.eq(user_id))
            .exec(&transaction)
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        for code_hash in hashes {
            mfa_backup_code::ActiveModel {
                id: Set(Uuid::new_v4()),
                user_id: Set(user_id),
                code_hash: Set(code_hash),
                created_at: Set(Utc::now().into()),
            }
            .insert(&transaction)
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        }
        transaction
            .commit()
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))
    }

    /// Disable MFA and remove all recovery material atomically.
    pub async fn disable_mfa(&self, user_id: Uuid) -> Result<()> {
        let transaction = self
            .db
            .begin()
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        let updated = user::Entity::update_many()
            .col_expr(user::Column::MfaEnabled, Expr::value(false))
            .col_expr(
                user::Column::MfaTotpSecretEncrypted,
                Expr::value(Option::<String>::None),
            )
            .col_expr(
                user::Column::MfaLastTotpStep,
                Expr::value(Option::<i64>::None),
            )
            .col_expr(user::Column::FailedMfaAttempts, Expr::value(0))
            .col_expr(user::Column::UpdatedAt, Expr::value(Utc::now()))
            .filter(user::Column::Id.eq(user_id))
            .filter(user::Column::MfaEnabled.eq(true))
            .exec(&transaction)
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        if updated.rows_affected != 1 {
            return Err(TidewayError::bad_request("MFA is not enabled or the user does not exist"));
        }
        mfa_backup_code::Entity::delete_many()
            .filter(mfa_backup_code::Column::UserId.eq(user_id))
            .exec(&transaction)
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        transaction
            .commit()
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))
    }
    {{/if}}
}

#[async_trait]
impl UserStore for DbUserStore {
    type User = user::Model;

    async fn find_by_email(&self, email: &str) -> Result<Option<Self::User>> {
        user::Entity::find()
            .filter(user::Column::Email.eq(email.trim().to_lowercase()))
            .one(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))
    }

    async fn find_by_id(&self, id: &str) -> Result<Option<Self::User>> {
        user::Entity::find_by_id(Self::parse_user_id(id)?)
            .one(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))
    }

    fn user_id(&self, user: &Self::User) -> String {
        user.id.to_string()
    }

    fn user_email(&self, user: &Self::User) -> String {
        user.email.clone()
    }

    fn user_name(&self, user: &Self::User) -> Option<String> {
        user.name.clone()
    }

    async fn get_password_hash(&self, user: &Self::User) -> Result<String> {
        Ok(user.password_hash.clone())
    }

    async fn update_password_hash(&self, user: &Self::User, hash: &str) -> Result<()> {
        let mut active: user::ActiveModel = user.clone().into();
        active.password_hash = Set(hash.to_owned());
        active.updated_at = Set(Utc::now().into());
        active
            .update(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;
        Ok(())
    }

    async fn is_verified(&self, user: &Self::User) -> Result<bool> {
        Ok(user.email_verified_at.is_some())
    }

    async fn mark_verified(&self, user: &Self::User) -> Result<()> {
        let mut active: user::ActiveModel = user.clone().into();
        active.email_verified_at = Set(Some(Utc::now().into()));
        active.updated_at = Set(Utc::now().into());
        active
            .update(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;
        Ok(())
    }

    async fn is_locked(&self, user: &Self::User) -> Result<Option<SystemTime>> {
        Ok(user.locked_until.map(Into::into))
    }

    async fn record_failed_attempt(&self, user: &Self::User) -> Result<()> {
        const MAX_FAILED_ATTEMPTS: i32 = 5;
        user::Entity::update_many()
            .col_expr(
                user::Column::FailedAttempts,
                Expr::col(user::Column::FailedAttempts).add(1),
            )
            .col_expr(user::Column::UpdatedAt, Expr::value(Utc::now()))
            .filter(user::Column::Id.eq(user.id))
            .exec(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;

        let failed_attempts = user::Entity::find_by_id(user.id)
            .one(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?
            .ok_or_else(|| TidewayError::not_found("User not found"))?
            .failed_attempts;
        if failed_attempts >= MAX_FAILED_ATTEMPTS {
            user::Entity::update_many()
                .col_expr(
                    user::Column::LockedUntil,
                    Expr::value(Some(Utc::now() + Duration::minutes(15))),
                )
                .filter(user::Column::Id.eq(user.id))
                .exec(self.db.as_ref())
                .await
                .map_err(|e| TidewayError::Database(e.to_string()))?;
        }
        Ok(())
    }

    {{#if has_auth_mfa_feature}}
    async fn record_failed_mfa_attempt(&self, user: &Self::User) -> Result<()> {
        const MAX_FAILED_MFA_ATTEMPTS: i32 = 5;
        user::Entity::update_many()
            .col_expr(
                user::Column::FailedMfaAttempts,
                Expr::col(user::Column::FailedMfaAttempts).add(1),
            )
            .col_expr(user::Column::UpdatedAt, Expr::value(Utc::now()))
            .filter(user::Column::Id.eq(user.id))
            .exec(self.db.as_ref())
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;

        let failed = user::Entity::find_by_id(user.id)
            .one(self.db.as_ref())
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?
            .ok_or_else(|| TidewayError::not_found("User not found"))?
            .failed_mfa_attempts;
        if failed >= MAX_FAILED_MFA_ATTEMPTS {
            user::Entity::update_many()
                .col_expr(
                    user::Column::LockedUntil,
                    Expr::value(Some(Utc::now() + Duration::minutes(15))),
                )
                .filter(user::Column::Id.eq(user.id))
                .exec(self.db.as_ref())
                .await
                .map_err(|error| TidewayError::Database(error.to_string()))?;
        }
        Ok(())
    }
    {{/if}}

    async fn clear_failed_attempts(&self, user: &Self::User) -> Result<()> {
        let mut active: user::ActiveModel = user.clone().into();
        active.failed_attempts = Set(0);
        {{#if has_auth_mfa_feature}}
        active.failed_mfa_attempts = Set(0);
        {{/if}}
        active.locked_until = Set(None);
        active.updated_at = Set(Utc::now().into());
        active
            .update(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;
        Ok(())
    }

    async fn has_mfa_enabled(&self, user: &Self::User) -> Result<bool> {
        {{#if has_auth_mfa_feature}}
        return Ok(user.mfa_enabled && user.mfa_totp_secret_encrypted.is_some());
        {{else}}
        let _ = user;
        Ok(false)
        {{/if}}
    }

    {{#if has_auth_mfa_feature}}
    async fn get_totp_secret(&self, user: &Self::User) -> Result<Option<String>> {
        user.mfa_totp_secret_encrypted
            .as_deref()
            .map(|encrypted| self.mfa_cipher.decrypt(&user.id.to_string(), encrypted))
            .transpose()
    }

    async fn consume_totp_step(&self, user: &Self::User, step: u64) -> Result<bool> {
        let step = i64::try_from(step)
            .map_err(|_| TidewayError::bad_request("Invalid TOTP time step"))?;
        let consumed = user::Entity::update_many()
            .col_expr(user::Column::MfaLastTotpStep, Expr::value(Some(step)))
            .col_expr(user::Column::UpdatedAt, Expr::value(Utc::now()))
            .filter(user::Column::Id.eq(user.id))
            .filter(user::Column::MfaEnabled.eq(true))
            .filter(
                Condition::any()
                    .add(user::Column::MfaLastTotpStep.is_null())
                    .add(user::Column::MfaLastTotpStep.lt(step)),
            )
            .exec(self.db.as_ref())
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;
        Ok(consumed.rows_affected == 1)
    }

    async fn get_backup_codes(&self, user: &Self::User) -> Result<Vec<String>> {
        mfa_backup_code::Entity::find()
            .filter(mfa_backup_code::Column::UserId.eq(user.id))
            .order_by_asc(mfa_backup_code::Column::CreatedAt)
            .all(self.db.as_ref())
            .await
            .map(|codes| codes.into_iter().map(|code| code.code_hash).collect())
            .map_err(|error| TidewayError::Database(error.to_string()))
    }

    async fn remove_backup_code(&self, user: &Self::User, index: usize) -> Result<()> {
        let code = mfa_backup_code::Entity::find()
            .filter(mfa_backup_code::Column::UserId.eq(user.id))
            .order_by_asc(mfa_backup_code::Column::CreatedAt)
            .all(self.db.as_ref())
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?
            .into_iter()
            .nth(index);
        if let Some(code) = code {
            mfa_backup_code::Entity::delete_by_id(code.id)
                .exec(self.db.as_ref())
                .await
                .map_err(|error| TidewayError::Database(error.to_string()))?;
        }
        Ok(())
    }

    async fn consume_backup_code(
        &self,
        user: &Self::User,
        code: &str,
    ) -> Result<Option<usize>> {
        let stored_codes = mfa_backup_code::Entity::find()
            .filter(mfa_backup_code::Column::UserId.eq(user.id))
            .order_by_asc(mfa_backup_code::Column::CreatedAt)
            .all(self.db.as_ref())
            .await
            .map_err(|error| TidewayError::Database(error.to_string()))?;

        for stored in stored_codes {
            if BackupCodeGenerator::verify_hash(code, &stored.code_hash).await? {
                let deleted = mfa_backup_code::Entity::delete_by_id(stored.id)
                    .exec(self.db.as_ref())
                    .await
                    .map_err(|error| TidewayError::Database(error.to_string()))?;
                if deleted.rows_affected != 1 {
                    return Ok(None);
                }
                let remaining = mfa_backup_code::Entity::find()
                    .filter(mfa_backup_code::Column::UserId.eq(user.id))
                    .count(self.db.as_ref())
                    .await
                    .map_err(|error| TidewayError::Database(error.to_string()))?;
                return Ok(Some(remaining as usize));
            }
        }
        Ok(None)
    }
    {{/if}}
}

#[async_trait]
impl UserCreator for DbUserStore {
    type User = user::Model;

    fn user_id(&self, user: &Self::User) -> String {
        user.id.to_string()
    }

    async fn email_exists(&self, email: &str) -> Result<bool> {
        Ok(UserStore::find_by_email(self, email).await?.is_some())
    }

    async fn create_user(
        &self,
        email: &str,
        password_hash: &str,
        name: Option<&str>,
    ) -> Result<Self::User> {
        let now = Utc::now();
        user::ActiveModel {
            id: Set(Uuid::new_v4()),
            email: Set(email.trim().to_lowercase()),
            password_hash: Set(password_hash.to_owned()),
            name: Set(name.map(str::to_owned)),
            email_verified_at: Set((!self.require_email_verification).then(|| now.into())),
            locked_until: Set(None),
            failed_attempts: Set(0),
            {{#if has_auth_mfa_feature}}
            failed_mfa_attempts: Set(0),
            mfa_enabled: Set(false),
            mfa_totp_secret_encrypted: Set(None),
            mfa_last_totp_step: Set(None),
            {{/if}}
            created_at: Set(now.into()),
            updated_at: Set(now.into()),
        }
        .insert(self.db.as_ref())
        .await
        .map_err(|e| TidewayError::Database(e.to_string()))
    }

    async fn send_verification_email(&self, user: &Self::User) -> Result<()> {
        if self.require_email_verification {
            tracing::warn!(
                user_id = %user.id,
                "Email verification is required; implement delivery in DbUserStore::send_verification_email"
            );
        }
        Ok(())
    }
}

#[async_trait]
impl PasswordResetStore for DbUserStore {
    type User = user::Model;

    async fn find_by_email(&self, email: &str) -> Result<Option<Self::User>> {
        UserStore::find_by_email(self, email).await
    }

    fn user_id(&self, user: &Self::User) -> String {
        user.id.to_string()
    }

    async fn store_reset_token(
        &self,
        user_id: &str,
        token_hash: &str,
        expires: SystemTime,
    ) -> Result<()> {
        let expires_at: chrono::DateTime<Utc> = expires.into();
        auth_token::ActiveModel {
            id: Set(Uuid::new_v4()),
            user_id: Set(Self::parse_user_id(user_id)?),
            token_hash: Set(token_hash.to_owned()),
            token_type: Set("password_reset".to_owned()),
            expires_at: Set(expires_at.into()),
            used_at: Set(None),
            created_at: Set(Utc::now().into()),
        }
        .insert(self.db.as_ref())
        .await
        .map_err(|e| TidewayError::Database(e.to_string()))?;
        Ok(())
    }

    async fn consume_reset_token(&self, token_hash: &str) -> Result<Option<String>> {
        let now = Utc::now();
        let token = auth_token::Entity::find()
            .filter(auth_token::Column::TokenHash.eq(token_hash))
            .filter(auth_token::Column::TokenType.eq("password_reset"))
            .filter(auth_token::Column::UsedAt.is_null())
            .filter(auth_token::Column::ExpiresAt.gt(now))
            .one(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;

        let Some(token) = token else {
            return Ok(None);
        };

        let update = auth_token::Entity::update_many()
            .col_expr(auth_token::Column::UsedAt, Expr::value(Some(Utc::now())))
            .filter(auth_token::Column::Id.eq(token.id))
            .filter(auth_token::Column::UsedAt.is_null())
            .filter(auth_token::Column::ExpiresAt.gt(Utc::now()))
            .exec(self.db.as_ref())
            .await
            .map_err(|e| TidewayError::Database(e.to_string()))?;

        Ok((update.rows_affected == 1).then(|| token.user_id.to_string()))
    }

    async fn update_password(&self, user_id: &str, hash: &str) -> Result<()> {
        let user = UserStore::find_by_id(self, user_id)
            .await?
            .ok_or_else(|| TidewayError::not_found("User not found"))?;
        self.update_password_hash(&user, hash).await
    }

    async fn invalidate_sessions(&self, user_id: &str) -> Result<()> {
        DbRefreshTokenStore::new(self.db.clone())
            .revoke_all_for_user(user_id)
            .await
    }

    async fn send_reset_email(
        &self,
        user: &Self::User,
        _token: &str,
        _expires_in: std::time::Duration,
    ) -> Result<()> {
        tracing::warn!(
            user_id = %user.id,
            "Password reset requested; implement delivery in DbUserStore::send_reset_email"
        );
        Ok(())
    }
}

