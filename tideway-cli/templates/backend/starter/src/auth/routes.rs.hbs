fn user_store(state: &AuthState) -> DbUserStore {
    DbUserStore::new(
        state.db.clone(),
        state.require_email_verification,
        {{#if has_auth_mfa_feature}}
        state.mfa_cipher.clone().expect("MFA cipher validated when routes were built"),
        {{/if}}
    )
}

enum AuthRouteError {
    Tideway(tideway::TidewayError),
    RateLimited { message: String, retry_after: u64 },
}

impl From<tideway::TidewayError> for AuthRouteError {
    fn from(error: tideway::TidewayError) -> Self {
        Self::Tideway(error)
    }
}

impl IntoResponse for AuthRouteError {
    fn into_response(self) -> Response {
        match self {
            Self::Tideway(error) => error.into_response(),
            Self::RateLimited {
                message,
                retry_after,
            } => {
                let mut response = tideway::TidewayError::TooManyRequests(message).into_response();
                response.headers_mut().insert(
                    RETRY_AFTER,
                    HeaderValue::from_str(&retry_after.to_string())
                        .expect("retry-after seconds are a valid header value"),
                );
                response
            }
        }
    }
}

type AuthRouteResult<T> = std::result::Result<T, AuthRouteError>;

fn enforce_auth_rate_limit(
    state: &AuthState,
    limiter: &AuthRateLimiter,
    endpoint: &'static str,
    address: SocketAddr,
    headers: &HeaderMap,
) -> AuthRouteResult<()> {
    let client_ip = state.client_ip_resolver.resolve(address.ip(), headers);
    if let Err(retry_after) = limiter.check(&client_ip.to_string()) {
        tracing::warn!(
            target: "auth.endpoint.rate_limited",
            endpoint,
            ip = %client_ip,
            retry_after_secs = retry_after,
            "Authentication endpoint rate limited"
        );
        return Err(AuthRouteError::RateLimited {
            message: format!(
                "Too many {endpoint} attempts. Please try again in {retry_after} seconds."
            ),
            retry_after,
        });
    }
    Ok(())
}

{{#if has_openapi_feature}}
#[utoipa::path(
    post,
    path = "/auth/register",
    tag = "Authentication",
    request_body = RegisterBody,
    responses(
        (status = 200, description = "User registered", body = RegisterResponse),
        (status = 400, description = "Invalid registration", body = tideway::ErrorResponse),
        (status = 429, description = "Rate limited", body = tideway::ErrorResponse)
    )
)]
{{/if}}
async fn register(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<RegisterBody>,
) -> AuthRouteResult<Json<RegisterResponse>> {
    enforce_auth_rate_limit(
        &state,
        &state.registration_rate_limiter,
        "registration",
        address,
        &headers,
    )?;
    let flow = RegistrationFlow::new(user_store(&state));
    let user = flow
        .register(RegisterRequest {
            email: body.email,
            password: body.password,
            name: body.name,
        })
        .await?;

    Ok(Json(RegisterResponse {
        user_id: user.id.to_string(),
        message: "Registration successful",
    }))
}

{{#if has_openapi_feature}}
#[utoipa::path(
    post,
    path = "/auth/login",
    tag = "Authentication",
    request_body = LoginBody,
    responses(
        (status = 200, description = "Login succeeded or MFA is required", body = tideway::auth::LoginResponse),
        (status = 401, description = "Invalid credentials", body = tideway::ErrorResponse),
        (status = 403, description = "Email verification required", body = tideway::ErrorResponse),
        (status = 423, description = "Account temporarily locked", body = tideway::ErrorResponse),
        (status = 429, description = "Rate limited", body = tideway::ErrorResponse)
    )
)]
{{/if}}
async fn login(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<LoginBody>,
) -> Result<LoginHttpResponse> {
    let flow = LoginFlow::new(
        user_store(&state),
        state.mfa_tokens.clone(),
        AppTokenIssuer::new(state.jwt_issuer.clone()),
        LoginFlowConfig::new(state.app_name.as_ref())
            .require_verification(state.require_email_verification),
    )
    .with_refresh_store(DbRefreshTokenStore::new(state.db.clone()))
    .with_rate_limiter(state.login_rate_limiter.clone());

    let client_ip = Some(
        state
            .client_ip_resolver
            .resolve(address.ip(), &headers)
            .to_string(),
    );
    let response = flow
        .login_with_ip(
            LoginRequest {
                email: body.email,
                password: body.password,
                remember_me: body.remember_me.unwrap_or(false),
                mfa_code: body.mfa_code,
            },
            client_ip,
        )
        .await?;

    Ok(response.into())
}

