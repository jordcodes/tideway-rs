use std::{net::SocketAddr, sync::Arc};

use axum::{
    body::{to_bytes, Body},
    extract::ConnectInfo,
    http::{header, Method, Request, StatusCode},
    Extension, Router,
};
use migration::{Migrator, MigratorTrait};
use sea_orm::Database;
use serde_json::{json, Value};
use tideway::{auth::{JwtIssuer, JwtIssuerConfig{{#if has_auth_mfa_feature}}, MfaSecretCipher, TotpConfig, TotpManager{{/if}}}, App};
use tower::ServiceExt;

use super::{AuthModule, SimpleAuthProvider};

const JWT_SECRET: &str = "test-only-secret-with-at-least-32-bytes";

async fn test_app() -> Router {
    let db = Database::connect("sqlite::memory:")
        .await
        .expect("connect to in-memory sqlite");
    Migrator::up(&db, None).await.expect("run migrations");
    let db = Arc::new(db);
    let issuer = Arc::new(
        JwtIssuer::new(
            JwtIssuerConfig::with_secure_secret(JWT_SECRET, env!("CARGO_PKG_NAME"))
                .expect("valid secret")
                .audience(env!("CARGO_PKG_NAME")),
        )
        .expect("create issuer"),
    );
    let provider = SimpleAuthProvider::from_secret(JWT_SECRET, db.clone());
    let auth = AuthModule::new(db, issuer, JWT_SECRET.to_owned(), env!("CARGO_PKG_NAME"))
        {{#if has_auth_mfa_feature}}
        .with_mfa_cipher(Arc::new(
            MfaSecretCipher::from_base64("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=")
                .expect("valid test MFA key"),
        ))
        {{/if}}
        ;

    App::new()
        .register_module(auth)
        .into_router()
        .layer(Extension(provider))
}

async fn request(app: &Router, method: Method, path: &str, body: Value) -> (StatusCode, Value) {
    let mut request = Request::builder()
        .method(method)
        .uri(path)
        .header(header::CONTENT_TYPE, "application/json")
        .body(Body::from(body.to_string()))
        .expect("build request");
    request.extensions_mut().insert(ConnectInfo(
        "127.0.0.1:40000".parse::<SocketAddr>().expect("socket address"),
    ));

    let response = app.clone().oneshot(request).await.expect("route response");
    let status = response.status();
    let bytes = to_bytes(response.into_body(), 1024 * 1024)
        .await
        .expect("read response body");
    let body = serde_json::from_slice(&bytes).unwrap_or(Value::Null);
    (status, body)
}

{{#if has_auth_mfa_feature}}
async fn authenticated_request(
    app: &Router,
    method: Method,
    path: &str,
    access_token: &str,
    body: Value,
) -> (StatusCode, axum::http::HeaderMap, Value) {
    let request = Request::builder()
        .method(method)
        .uri(path)
        .header(header::CONTENT_TYPE, "application/json")
        .header(header::AUTHORIZATION, format!("Bearer {access_token}"))
        .body(Body::from(body.to_string()))
        .expect("build authenticated request");

    let response = app.clone().oneshot(request).await.expect("route response");
    let status = response.status();
    let headers = response.headers().clone();
    let bytes = to_bytes(response.into_body(), 1024 * 1024)
        .await
        .expect("read response body");
    let body = serde_json::from_slice(&bytes).unwrap_or(Value::Null);
    (status, headers, body)
}
{{/if}}

#[tokio::test]
async fn register_login_refresh_me_and_logout_lifecycle() {
    let app = test_app().await;
    let email = "developer@example.com";
    let password = "correct horse battery staple";

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/register",
        json!({"email": email, "password": password, "name": "Developer"}),
    )
    .await;
    assert_eq!(status, StatusCode::OK);

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": "wrong password"}),
    )
    .await;
    assert_eq!(status, StatusCode::UNAUTHORIZED);

    let (status, login) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "login response: {login}");
    let access = login["access_token"].as_str().expect("access token");
    let refresh = login["refresh_token"].as_str().expect("refresh token");

    let me_request = Request::builder()
        .method(Method::GET)
        .uri("/auth/me")
        .header(header::AUTHORIZATION, format!("Bearer {access}"))
        .body(Body::empty())
        .expect("build me request");
    let me_response = app.clone().oneshot(me_request).await.expect("me response");
    assert_eq!(me_response.status(), StatusCode::OK);

    let (status, refreshed) = request(
        &app,
        Method::POST,
        "/auth/refresh",
        json!({"refresh_token": refresh}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "refresh response: {refreshed}");
    let rotated_refresh = refreshed["refresh_token"]
        .as_str()
        .expect("rotated refresh token");

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/logout",
        json!({"refresh_token": rotated_refresh}),
    )
    .await;
    assert_eq!(status, StatusCode::OK);

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/refresh",
        json!({"refresh_token": rotated_refresh}),
    )
    .await;
    assert_eq!(status, StatusCode::UNAUTHORIZED);
}

{{#if has_auth_mfa_feature}}
#[tokio::test]
async fn mfa_enrollment_challenge_and_backup_codes_are_one_time() {
    let app = test_app().await;
    let email = "mfa-developer@example.com";
    let password = "correct horse battery staple";

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/register",
        json!({"email": email, "password": password, "name": "MFA Developer"}),
    )
    .await;
    assert_eq!(status, StatusCode::OK);

    let (status, login) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "login response: {login}");
    let access = login["access_token"].as_str().expect("access token");

    let (status, headers, setup) = authenticated_request(
        &app,
        Method::POST,
        "/auth/mfa/setup",
        access,
        json!({"password": password}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "setup response: {setup}");
    assert_eq!(headers.get(header::CACHE_CONTROL).unwrap(), "no-store");
    let secret = setup["secret"].as_str().expect("TOTP secret");
    let code = TotpManager::new(TotpConfig::new(env!("CARGO_PKG_NAME")))
        .generate_current(secret, email)
        .expect("current TOTP code");

    let (status, headers, enabled) = authenticated_request(
        &app,
        Method::POST,
        "/auth/mfa/enable",
        access,
        json!({"password": password, "secret": secret, "code": code}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "enable response: {enabled}");
    assert_eq!(headers.get(header::CACHE_CONTROL).unwrap(), "no-store");
    let backup_code = enabled["backup_codes"][0]
        .as_str()
        .expect("backup code")
        .to_owned();

    let (status, challenge) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "challenge response: {challenge}");
    let mfa_token = challenge["mfa_token"].as_str().expect("MFA token");
    let code = TotpManager::new(TotpConfig::new(env!("CARGO_PKG_NAME")))
        .generate_current(secret, email)
        .expect("current TOTP code");

    let (status, verified) = request(
        &app,
        Method::POST,
        "/auth/mfa/verify",
        json!({"mfa_token": mfa_token, "code": code}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "verify response: {verified}");
    assert!(verified["access_token"].is_string());

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/mfa/verify",
        json!({"mfa_token": mfa_token, "code": code}),
    )
    .await;
    assert_eq!(status, StatusCode::UNAUTHORIZED);

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password, "mfa_code": code}),
    )
    .await;
    assert_eq!(status, StatusCode::UNAUTHORIZED, "TOTP code must not be replayable");

    let (status, recovered) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password, "mfa_code": backup_code}),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "backup login response: {recovered}");
    assert!(recovered["access_token"].is_string());

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({"email": email, "password": password, "mfa_code": backup_code}),
    )
    .await;
    assert_eq!(status, StatusCode::UNAUTHORIZED);
}
{{/if}}
