        (status = 423, description = "Account temporarily locked", body = tideway::ErrorResponse)
    )
)]
{{/if}}
async fn verify_mfa(
    Extension(state): Extension<AuthState>,
    Json(body): Json<MfaVerifyBody>,
) -> Result<LoginHttpResponse> {
    let flow = LoginFlow::new(
        user_store(&state),
        state.mfa_tokens.clone(),
        AppTokenIssuer::new(state.jwt_issuer.clone()),
        LoginFlowConfig::new(state.app_name.as_ref())
            .require_verification(state.require_email_verification),
    )
    .with_refresh_store(DbRefreshTokenStore::new(state.db.clone()))
    .with_rate_limiter(state.login_rate_limiter.clone());

    let response = flow
        .verify_mfa(MfaVerifyRequest {
            mfa_token: body.mfa_token,
            code: body.code,
        })
        .await?;
    Ok(response.into())
}

async fn reauthenticate_mfa_change(
    state: &AuthState,
    actor: &SimpleUser,
    password: &str,
) -> Result<(DbUserStore, crate::entities::user::Model)> {
    let store = user_store(state);
    let user = UserStore::find_by_id(&store, &actor.id)
        .await?
        .ok_or_else(|| tideway::TidewayError::unauthorized("Invalid credentials"))?;
    if store.is_locked(&user).await?.is_some() {
        return Err(tideway::TidewayError::unauthorized("Account temporarily locked"));
    }
    let password_hash = store.get_password_hash(&user).await?;
    if !PasswordHasher::default()
        .verify_async(password, &password_hash)
        .await?
    {
        store.record_failed_attempt(&user).await?;
        return Err(tideway::TidewayError::unauthorized("Invalid credentials"));
    }
    Ok((store, user))
}

{{#if has_openapi_feature}}
#[utoipa::path(
    post,
    path = "/auth/mfa/setup",
    tag = "MFA",
    request_body = MfaSetupBody,
    responses(
        (status = 200, description = "Temporary TOTP setup data; do not cache", body = MfaSetupResponse),
        (status = 400, description = "MFA is already enabled", body = tideway::ErrorResponse),
        (status = 401, description = "Reauthentication failed", body = tideway::ErrorResponse)
    ),
    security(("bearer_auth" = []))
)]
{{/if}}
async fn setup_mfa(
    AuthUser(actor): AuthUser<SimpleAuthProvider>,
    Extension(state): Extension<AuthState>,
    Json(body): Json<MfaSetupBody>,
) -> Result<Response> {
    let (_, user) = reauthenticate_mfa_change(&state, &actor, &body.password).await?;
    if user.mfa_enabled {
        return Err(tideway::TidewayError::bad_request("MFA is already enabled"));
    }
    let setup = TotpManager::new(TotpConfig::new(state.app_name.as_ref()))
        .generate_setup(&user.email)?;
    Ok((
        [(CACHE_CONTROL, "no-store"), (PRAGMA, "no-cache")],
        Json(MfaSetupResponse {
            secret: setup.secret,
            uri: setup.uri,
            qr_code_base64: setup.qr_code_base64,
        }),
    )
        .into_response())
}

{{#if has_openapi_feature}}
#[utoipa::path(
    post,
    path = "/auth/mfa/enable",
    tag = "MFA",
    request_body = MfaEnableBody,
    responses(
        (status = 200, description = "MFA enabled; recovery codes are returned once", body = MfaEnableResponse),
        (status = 400, description = "MFA is already enabled", body = tideway::ErrorResponse),
        (status = 401, description = "Password or MFA code is invalid", body = tideway::ErrorResponse)
    ),
    security(("bearer_auth" = []))
)]
{{/if}}
async fn enable_mfa(
    AuthUser(actor): AuthUser<SimpleAuthProvider>,
    Extension(state): Extension<AuthState>,
    Json(body): Json<MfaEnableBody>,
) -> Result<Response> {
    let (store, user) = reauthenticate_mfa_change(&state, &actor, &body.password).await?;
    if user.mfa_enabled {
        return Err(tideway::TidewayError::bad_request("MFA is already enabled"));
    }
    let manager = TotpManager::new(TotpConfig::new(state.app_name.as_ref()));
    if !manager.verify(&body.secret, &body.code, &user.email)? {
        store.record_failed_mfa_attempt(&user).await?;
        return Err(tideway::TidewayError::unauthorized("Invalid MFA code"));
    }

    let backup_codes = BackupCodeGenerator::default().generate();
    store
        .enable_mfa(user.id, &body.secret, &backup_codes.codes)
        .await?;
    tracing::info!(target: "auth.mfa.enabled", user_id = %user.id, "MFA enabled");
    Ok((
        [(CACHE_CONTROL, "no-store"), (PRAGMA, "no-cache")],
        Json(MfaEnableResponse {
            backup_codes: backup_codes.display_codes(),
        }),
    )
        .into_response())
}

{{#if has_openapi_feature}}
#[utoipa::path(
    delete,
    path = "/auth/mfa",
    tag = "MFA",
    request_body = MfaDisableBody,
    responses(
        (status = 200, description = "MFA disabled", body = tideway::MessageResponse),
        (status = 400, description = "MFA is not enabled", body = tideway::ErrorResponse),
        (status = 401, description = "Password or MFA code is invalid", body = tideway::ErrorResponse)
    ),
    security(("bearer_auth" = []))
)]
{{/if}}
async fn disable_mfa(
    AuthUser(actor): AuthUser<SimpleAuthProvider>,
    Extension(state): Extension<AuthState>,
    Json(body): Json<MfaDisableBody>,
) -> Result<MessageResponse> {
    let (store, user) = reauthenticate_mfa_change(&state, &actor, &body.password).await?;
    let secret = store
        .get_totp_secret(&user)
        .await?
        .ok_or_else(|| tideway::TidewayError::bad_request("MFA is not enabled"))?;
    let manager = TotpManager::new(TotpConfig::new(state.app_name.as_ref()));
    let valid = match manager.verify_step(&secret, &body.code, &user.email)? {
        Some(step) => store.consume_totp_step(&user, step).await?,
        None => false,
    };
    if !valid {
        store.record_failed_mfa_attempt(&user).await?;
        return Err(tideway::TidewayError::unauthorized("Invalid MFA code"));
    }
    store.disable_mfa(user.id).await?;
    tracing::info!(target: "auth.mfa.disabled", user_id = %user.id, "MFA disabled");
    Ok(MessageResponse::success("MFA disabled"))
}
{{/if}}

{{#if has_openapi_feature}}
#[utoipa::path(
    post,
    path = "/auth/refresh",
    tag = "Authentication",
    request_body = RefreshBody,
    responses(
        (status = 200, description = "Token pair rotated", body = RefreshResponse),
        (status = 401, description = "Invalid or reused refresh token", body = tideway::ErrorResponse),
        (status = 429, description = "Rate limited", body = tideway::ErrorResponse)
    )
)]
{{/if}}
async fn refresh(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<RefreshBody>,
) -> AuthRouteResult<Json<RefreshResponse>> {
    enforce_auth_rate_limit(
        &state,
        &state.refresh_rate_limiter,
        "refresh",
        address,
        &headers,
    )?;
    let flow = TokenRefreshFlow::new(
        state.jwt_issuer.as_ref().clone(),
        DbRefreshTokenStore::new(state.db.clone()),
        user_store(&state),
        state.jwt_secret.as_bytes(),
    );
    let tokens = flow.refresh(&body.refresh_token).await?;

    Ok(Json(RefreshResponse {
        access_token: tokens.access_token,
        refresh_token: tokens.refresh_token,
        expires_in: tokens.expires_in,
        token_type: "Bearer",
    }))
}

