[package]
name = "{{project_name}}"
version = "0.1.0"
edition = "2021"

[dependencies]
tideway = { version = "{{tideway_version}}", default-features = false{{#if has_tideway_features}}, features = [{{#each tideway_features}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]{{/if}} }
tokio = { version = "1.48", features = ["macros", "rt-multi-thread"] }
axum = "0.8"
{{#if has_auth_feature}}
async-trait = "0.1"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
tracing = "0.1"
{{/if}}
{{#if has_database_feature}}
sea-orm = { version = "1.1", features = ["{{#if is_sqlite_database}}sqlx-sqlite{{else}}sqlx-postgres{{/if}}", "runtime-tokio-rustls"{{#if has_auth_feature}}, "with-chrono", "with-uuid"{{/if}}] }
migration = { path = "migration" }
{{#if has_auth_feature}}
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1", features = ["v4", "serde"] }
{{/if}}
{{/if}}
{{#if has_openapi_feature}}
utoipa = { version = "5", features = ["axum_extras"] }
{{/if}}
{{#if is_sqlite_database}}
{{#if has_auth_feature}}

[dev-dependencies]
tower = { version = "0.5", features = ["util"] }
{{/if}}
{{/if}}
