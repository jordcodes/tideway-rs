#[utoipa::path(
    post,
    path = "/auth/logout",
    tag = "Authentication",
    request_body = LogoutBody,
    responses(
        (status = 200, description = "Refresh-token family revoked", body = tideway::MessageResponse),
        (status = 401, description = "Invalid refresh token", body = tideway::ErrorResponse)
    )
)]
{{/if}}
async fn logout(
    Extension(state): Extension<AuthState>,
    Json(body): Json<LogoutBody>,
) -> Result<MessageResponse> {
    let flow = TokenRefreshFlow::new(
        state.jwt_issuer.as_ref().clone(),
        DbRefreshTokenStore::new(state.db.clone()),
        user_store(&state),
        state.jwt_secret.as_bytes(),
    );
    flow.revoke(&body.refresh_token).await?;
    Ok(MessageResponse::success("Logged out"))
}

async fn request_password_reset(
    ConnectInfo(address): ConnectInfo<SocketAddr>,
    headers: HeaderMap,
    Extension(state): Extension<AuthState>,
    Json(body): Json<PasswordResetBody>,
) -> AuthRouteResult<MessageResponse> {
    enforce_auth_rate_limit(
        &state,
        &state.email_rate_limiter,
        "password reset",
        address,
        &headers,
    )?;
    let email_key = format!("email:{}", body.email.trim().to_ascii_lowercase());
    if let Err(retry_after) = state.email_rate_limiter.check(&email_key) {
        return Err(AuthRouteError::RateLimited {
            message: "Too many password reset requests; try again later".to_string(),
            retry_after,
        });
    }
    let flow = PasswordResetFlow::new(user_store(&state));
    // Keep the public response generic to prevent account enumeration, but retain
    // enough operational visibility to diagnose a broken delivery integration.
    if let Err(error) = flow
        .request_reset(PasswordResetRequest { email: body.email })
        .await
    {
        tracing::error!(%error, "Password reset request failed");
    }
    Ok(MessageResponse::success(
        "If that account exists, password reset instructions have been sent.",
    ))
}

async fn complete_password_reset(
    Extension(state): Extension<AuthState>,
    Json(body): Json<PasswordResetCompleteBody>,
) -> Result<MessageResponse> {
    PasswordResetFlow::new(user_store(&state))
        .complete_reset(PasswordResetComplete {
            token: body.token,
            new_password: body.new_password,
        })
        .await?;
    Ok(MessageResponse::success("Password reset complete"))
}

