//! Application-owned transactional email templates and provider selection.

use std::sync::Arc;
use std::time::Duration;
use tideway::{
    ConsoleMailer, Email, Mailer, ResendMailer, Result, SmtpMailer, TidewayError,
};

fn escape_html(value: &str) -> String {
    value
        .replace('&', "&amp;")
        .replace('<', "&lt;")
        .replace('>', "&gt;")
        .replace('"', "&quot;")
        .replace('\'', "&#x27;")
}

fn transactional_email_html(
    app_name: &str,
    heading: &str,
    message: &str,
    action: &str,
    link: &str,
    expiry: &str,
    safety_note: &str,
) -> String {
    let app_name = escape_html(app_name);
    let heading = escape_html(heading);
    let message = escape_html(message);
    let action = escape_html(action);
    let link = escape_html(link);
    let expiry = escape_html(expiry);
    let safety_note = escape_html(safety_note);

    // Application-owned, deliberately neutral markup. Customize colours, copy,
    // and branding here while retaining the plain-text fallback below.
    format!(
        r#"<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{heading}</title>
</head>
<body style="margin:0;background:#f4f4f5;color:#18181b;font-family:Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;">{message}</div>
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f4f5;padding:32px 16px;">
    <tr><td align="center">
      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;background:#ffffff;border:1px solid #e4e4e7;border-radius:12px;">
        <tr><td style="padding:32px;">
          <p style="margin:0 0 24px;color:#52525b;font-size:14px;font-weight:700;">{app_name}</p>
          <h1 style="margin:0 0 16px;font-size:24px;line-height:1.3;">{heading}</h1>
          <p style="margin:0 0 24px;color:#3f3f46;font-size:16px;line-height:1.6;">{message}</p>
          <p style="margin:0 0 24px;">
            <a href="{link}" style="display:inline-block;background:#18181b;color:#ffffff;text-decoration:none;font-size:16px;font-weight:700;padding:12px 20px;border-radius:8px;">{action}</a>
          </p>
          <p style="margin:0 0 8px;color:#52525b;font-size:14px;line-height:1.5;">{expiry}</p>
          <p style="margin:0;color:#71717a;font-size:13px;line-height:1.5;">{safety_note}</p>
          <hr style="margin:28px 0;border:0;border-top:1px solid #e4e4e7;">
          <p style="margin:0;color:#71717a;font-size:12px;line-height:1.5;word-break:break-all;">If the button does not work, copy this link:<br>{link}</p>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>"#,
    )
}

/// Provider-neutral transactional email service.
#[derive(Clone)]
pub struct EmailService {
    mailer: Arc<dyn Mailer>,
    from: String,
    app_name: String,
    app_url: String,
}

impl EmailService {
    /// Build the service with an application-supplied provider.
    pub fn new(
        mailer: Arc<dyn Mailer>,
        from: impl Into<String>,
        app_name: impl Into<String>,
        app_url: impl Into<String>,
    ) -> Result<Self> {
        let from = from.into();
        if from.trim().is_empty() {
            return Err(TidewayError::internal("EMAIL_FROM must not be empty"));
        }

        Ok(Self {
            mailer,
            from,
            app_name: app_name.into(),
            app_url: app_url.into().trim_end_matches('/').to_string(),
        })
    }

    /// Select a provider using `EMAIL_PROVIDER`: `resend`, `smtp`, or `console`.
    /// Implement `Mailer` and replace the `custom` branch for another provider.
    pub fn from_env(environment: &str, app_name: impl Into<String>, app_url: impl Into<String>) -> Result<Self> {
        let provider = std::env::var("EMAIL_PROVIDER")
            .unwrap_or_else(|_| "console".to_string())
            .trim()
            .to_ascii_lowercase();
        let is_development = matches!(
            environment.trim().to_ascii_lowercase().as_str(),
            "development" | "dev" | "local" | "test"
        );
        let app_url = app_url.into();
        if !is_development && !app_url.to_ascii_lowercase().starts_with("https://") {
            return Err(TidewayError::internal(
                "APP_URL must use https outside development/test environments",
            ));
        }

        let mailer: Arc<dyn Mailer> = match provider.as_str() {
            "resend" => Arc::new(ResendMailer::from_env()?),
            "smtp" => Arc::new(SmtpMailer::from_env()?),
            "console" if is_development => {
                let show_body = std::env::var("EMAIL_CONSOLE_SHOW_BODY")
                    .map(|value| value.eq_ignore_ascii_case("true"))
                    .unwrap_or(false);
                Arc::new(ConsoleMailer::new().with_full_output(show_body))
            }
            "console" => {
                return Err(TidewayError::internal(
                    "EMAIL_PROVIDER=console is development-only; configure resend, smtp, or a custom Mailer",
                ));
            }
            "custom" => {
                return Err(TidewayError::internal(
                    "EMAIL_PROVIDER=custom requires an application Mailer implementation in src/email.rs",
                ));
            }
            _ => {
                return Err(TidewayError::internal(
                    "EMAIL_PROVIDER must be one of: resend, smtp, console, custom",
                ));
            }
        };

        let from = std::env::var("EMAIL_FROM")
            .map_err(|_| TidewayError::internal("EMAIL_FROM must be set"))?;
        Self::new(mailer, from, app_name, app_url)
    }

    pub async fn send_verification(
        &self,
        recipient: &str,
        token: &str,
        expires_in: Duration,
    ) -> Result<()> {
        let link = format!("{}/verify-email?token={}", self.app_url, token);
        let hours = expires_in.as_secs().div_ceil(3600);
        let text = format!(
            "Verify your email for {} by visiting:\n\n{}\n\nThis link expires in {} hour(s). If you did not create this account, ignore this email.",
            self.app_name, link, hours,
        );
        let html = transactional_email_html(
            &self.app_name,
            "Verify your email",
            "Confirm this email address to finish setting up your account.",
            "Verify email",
            &link,
            &format!("This link expires in {hours} hour(s)."),
            "If you did not create this account, you can safely ignore this email.",
        );
        let email = Email::new(&self.from, recipient, format!("Verify your {} email", self.app_name))
            .text(text)
            .html(html);
        self.mailer.send(&email).await
    }

    pub async fn send_password_reset(
        &self,
        recipient: &str,
        token: &str,
        expires_in: Duration,
    ) -> Result<()> {
        let link = format!("{}/reset-password?token={}", self.app_url, token);
        let minutes = expires_in.as_secs().div_ceil(60);
        let text = format!(
            "Reset your {} password by visiting:\n\n{}\n\nThis link expires in {} minute(s). If you did not request this, ignore this email.",
            self.app_name, link, minutes,
        );
        let html = transactional_email_html(
            &self.app_name,
            "Reset your password",
            "Use the button below to choose a new password for your account.",
            "Reset password",
            &link,
            &format!("This link expires in {minutes} minute(s)."),
            "If you did not request this reset, you can safely ignore this email.",
        );
        let email = Email::new(&self.from, recipient, format!("Reset your {} password", self.app_name))
            .text(text)
            .html(html);
        self.mailer.send(&email).await
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn transactional_html_is_accessible_and_escapes_application_values() {
        let html = transactional_email_html(
            "<script>alert('brand')</script>",
            "Verify & continue",
            "Confirm <this> address",
            "Verify \"now\"",
            "https://app.example.com/verify?token=a&next=\"home\"",
            "Expires soon",
            "Ignore if unexpected",
        );

        assert!(html.starts_with("<!doctype html>"));
        assert!(html.contains("role=\"presentation\""));
        assert!(html.contains("&lt;script&gt;"));
        assert!(html.contains("&amp;next=&quot;home&quot;"));
        assert!(!html.contains("<script>"));
    }
}
