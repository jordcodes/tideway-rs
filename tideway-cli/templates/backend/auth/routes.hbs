/// Auth module state.
#[derive(Clone)]
pub struct AuthState {
    // tideway:auth-registration-policy
    // tideway:auth-endpoint-rate-limits
    pub db: Arc<DatabaseConnection>,
    pub jwt_issuer: Arc<JwtIssuer>,
    pub jwt_secret: String,
    pub app_name: String,
    allow_public_registration: bool,
    require_email_verification: bool,
    email_delivery_enabled: bool,
    email_service: Option<Arc<EmailService>>,
    client_ip_resolver: Arc<ClientIpResolver>,
    login_rate_limiter: LoginRateLimiter,
    registration_rate_limiter: AuthRateLimiter,
    refresh_rate_limiter: AuthRateLimiter,
    email_rate_limiter: AuthRateLimiter,
    mfa_tokens: InMemoryMfaTokenStore,
}

/// Auth routes module implementing RouteModule pattern.
pub struct AuthModule {
    state: AuthState,
}

impl AuthModule {
    pub fn new(
        db: Arc<DatabaseConnection>,
        jwt_issuer: Arc<JwtIssuer>,
        jwt_secret: String,
        app_name: String,
    ) -> Self {
        let require_email_verification = std::env::var("REQUIRE_EMAIL_VERIFICATION")
            .map(|value| value.eq_ignore_ascii_case("true"))
            .unwrap_or(false);

        Self {
            state: AuthState {
                db,
                jwt_issuer,
                jwt_secret,
                app_name,
                allow_public_registration: false,
                require_email_verification,
                email_delivery_enabled: false,
                email_service: None,
                client_ip_resolver: Arc::new(
                    ClientIpResolver::from_env("TRUSTED_PROXY_IPS")
                        .expect("TRUSTED_PROXY_IPS must contain only non-catch-all IP addresses or CIDR networks"),
                ),
                login_rate_limiter: LoginRateLimiter::new(LoginRateLimitConfig::default()),
                registration_rate_limiter: AuthRateLimiter::new(AuthRateLimitConfig::new(5, 3600)),
                refresh_rate_limiter: AuthRateLimiter::new(AuthRateLimitConfig::new(60, 60)),
                email_rate_limiter: AuthRateLimiter::new(AuthRateLimitConfig::new(5, 3600)),
                mfa_tokens: InMemoryMfaTokenStore::default(),
            },
        }
    }

    /// Enable or disable public account registration. Disabled by default.
    pub fn with_public_registration(mut self, enabled: bool) -> Self {
        self.state.allow_public_registration = enabled;
        self
    }

    /// Override the per-IP registration rate limit.
    #[allow(dead_code)] // Generated production-policy extension point.
    pub fn with_registration_rate_limit(mut self, config: AuthRateLimitConfig) -> Self {
        self.state.registration_rate_limiter = AuthRateLimiter::new(config);
        self
    }

    /// Override the per-IP refresh rate limit.
    #[allow(dead_code)] // Generated production-policy extension point.
    pub fn with_refresh_rate_limit(mut self, config: AuthRateLimitConfig) -> Self {
        self.state.refresh_rate_limiter = AuthRateLimiter::new(config);
        self
    }

    /// Mount email-dependent auth routes with any configured provider.
    pub fn with_email_delivery(mut self, email_service: Arc<EmailService>) -> Self {
        self.state.email_delivery_enabled = true;
        self.state.email_service = Some(email_service);
        self
    }
}

impl RouteModule for AuthModule {
    fn routes(&self) -> Router<AppContext> {
        assert!(
            !self.state.require_email_verification || self.state.email_delivery_enabled,
            "REQUIRE_EMAIL_VERIFICATION=true requires AuthModule::with_email_delivery() and implemented delivery hooks",
        );

        let router = Router::new()
            .route("/login", post(login))
            .route("/logout", post(logout))
            .route("/refresh", post(refresh))
            {{#if has_auth_mfa_feature}}
            .route("/mfa/verify", post(verify_mfa))
            {{/if}}
            ;
        let router = if self.state.allow_public_registration {
            router.route("/register", post(register))
        } else {
            router
        };

        let router = if self.state.email_delivery_enabled {
            router
                .route("/password/reset", post(request_password_reset))
                .route("/password/reset/complete", post(complete_password_reset))
                .route("/email/verify", post(verify_email))
                .route("/email/verification/resend", post(resend_verification))
        } else {
            router
        };

        router.layer(Extension(self.state.clone()))
    }

    fn prefix(&self) -> Option<&str> {
        Some("/auth")
    }
}

