const JWT_SECRET: &str = "test-only-secret-with-at-least-32-bytes";
const DISPLAY_APP_NAME: &str = "Chairful API";
const JWT_ISSUER: &str = env!("CARGO_PKG_NAME");
const JWT_AUDIENCE: &str = env!("CARGO_PKG_NAME");

async fn connect_test_database() -> DatabaseConnection {
    let Ok(database_url) = std::env::var("TEST_DATABASE_URL") else {
        return Database::connect("sqlite::memory:")
            .await
            .expect("connect to in-memory sqlite");
    };
    let schema = format!("test_{}", uuid::Uuid::new_v4().simple());
    let admin = Database::connect(&database_url)
        .await
        .expect("connect to PostgreSQL test database");
    admin
        .execute(Statement::from_string(
            DatabaseBackend::Postgres,
            format!("CREATE SCHEMA \"{schema}\""),
        ))
        .await
        .expect("create isolated PostgreSQL test schema");
    let mut options = ConnectOptions::new(database_url);
    options.set_schema_search_path(schema);
    Database::connect(options)
        .await
        .expect("connect to isolated PostgreSQL test schema")
}

async fn test_app() -> Router {
    let db = connect_test_database().await;
    Migrator::up(&db, None).await.expect("run migrations");
    let db = Arc::new(db);
    let jwt = JwtAuth::new(
        JwtAuthConfig::with_secure_secret(JWT_SECRET, JWT_ISSUER)
            .expect("valid secret")
            .audience(JWT_AUDIENCE),
    )
    .expect("create paired auth");
    let issuer = jwt.issuer();
    let auth = AuthModule::new(
        db.clone(),
        issuer,
        JWT_SECRET.to_owned(),
        DISPLAY_APP_NAME.to_owned(),
    )
    .with_public_registration(true);

    let app = App::new().register_module(auth);
    {{#if has_organizations}}
    let app = app.register_module(OrganizationModule::new(
        db,
        jwt.verifier().expect("create verifier"),
    ));
    {{/if}}
    app.into_router()
}

#[tokio::test]
async fn public_registration_is_disabled_by_default() {
    let db = connect_test_database().await;
    Migrator::up(&db, None).await.expect("run migrations");
    let db = Arc::new(db);
    let jwt = JwtAuth::new(
        JwtAuthConfig::with_secure_secret(JWT_SECRET, JWT_ISSUER)
            .expect("valid secret")
            .audience(JWT_AUDIENCE),
    )
    .expect("create paired auth");
    let auth = AuthModule::new(
        db,
        jwt.issuer(),
        JWT_SECRET.to_owned(),
        DISPLAY_APP_NAME.to_owned(),
    );
    let app = App::new().register_module(auth).into_router();

    let (status, _) = request(
        &app,
        Method::POST,
        "/auth/register",
        json!({"email": "private@example.com", "password": "correct horse battery staple"}),
    )
    .await;
    assert_eq!(status, StatusCode::NOT_FOUND);
}

#[tokio::test]
async fn registration_and_refresh_are_rate_limited() {
    let app = test_app().await;
    for _ in 0..5 {
        let (status, _) = request(
            &app,
            Method::POST,
            "/auth/register",
            json!({
                "email": "invalid",
                "password": "correct horse battery staple"
                {{#if has_organizations}}, "organization_name": "Rate Limited Org"{{/if}}
            }),
        )
        .await;
        assert_eq!(status, StatusCode::BAD_REQUEST);
    }
    let (status, headers, _) = request_with_headers(
        &app,
        Method::POST,
        "/auth/register",
        json!({
            "email": "invalid",
            "password": "correct horse battery staple"
            {{#if has_organizations}}, "organization_name": "Rate Limited Org"{{/if}}
        }),
    )
    .await;
    assert_eq!(status, StatusCode::TOO_MANY_REQUESTS);
    assert!(headers.contains_key(header::RETRY_AFTER));

    for _ in 0..60 {
        let (status, _) = request(
            &app,
            Method::POST,
            "/auth/refresh",
            json!({"refresh_token": "invalid"}),
        )
        .await;
        assert_eq!(status, StatusCode::UNAUTHORIZED);
    }
    let (status, headers, _) = request_with_headers(
        &app,
        Method::POST,
        "/auth/refresh",
        json!({"refresh_token": "invalid"}),
    )
    .await;
    assert_eq!(status, StatusCode::TOO_MANY_REQUESTS);
    assert!(headers.contains_key(header::RETRY_AFTER));
}

async fn request(app: &Router, method: Method, path: &str, body: Value) -> (StatusCode, Value) {
    request_with_token(app, method, path, body, None).await
}

async fn request_with_headers(
    app: &Router,
    method: Method,
    path: &str,
    body: Value,
) -> (StatusCode, HeaderMap, Value) {
    request_with_token_and_headers(app, method, path, body, None).await
}

async fn request_with_token(
    app: &Router,
    method: Method,
    path: &str,
    body: Value,
    token: Option<&str>,
) -> (StatusCode, Value) {
    let (status, _, body) = request_with_token_and_headers(app, method, path, body, token).await;
    (status, body)
}

async fn request_with_token_and_headers(
    app: &Router,
    method: Method,
    path: &str,
    body: Value,
    token: Option<&str>,
) -> (StatusCode, HeaderMap, Value) {
    let mut request = Request::builder()
        .method(method)
        .uri(path)
        .header(header::CONTENT_TYPE, "application/json");
    if let Some(token) = token {
        request = request.header(header::AUTHORIZATION, format!("Bearer {token}"));
    }
    let mut request = request.body(Body::from(body.to_string())).expect("build request");
    request.extensions_mut().insert(ConnectInfo(
        "127.0.0.1:40000"
            .parse::<SocketAddr>()
            .expect("socket address"),
    ));

    let response = app.clone().oneshot(request).await.expect("route response");
    let status = response.status();
    let headers = response.headers().clone();
    let bytes = to_bytes(response.into_body(), 1024 * 1024)
        .await
        .expect("read response body");
    let body = serde_json::from_slice(&bytes).unwrap_or(Value::Null);
    (status, headers, body)
}

#[tokio::test]
async fn registration_and_login_work_with_generated_migrations() {
    let app = test_app().await;
    let email = "developer@example.com";
    let password = "correct horse battery staple";
    let registration = json!({
        "email": email,
        "password": password,
        "name": "Developer"
        {{#if has_organizations}}
        , "organization_name": "Example Organization"
        {{/if}}
    });

    let (status, registered) = request(&app, Method::POST, "/auth/register", registration).await;
    assert_eq!(status, StatusCode::OK, "registration response: {registered}");
    assert_eq!(registered["success"], true);
    assert!(registered["user_id"].is_string());
    {{#if has_organizations}}
    assert!(registered["organization_id"].is_string());
    {{/if}}

    let (status, login) = request(
        &app,
        Method::POST,
        "/auth/login",
        json!({
            "email": email,
            "password": password,
            "remember_me": false
        }),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "login response: {login}");
    assert!(login["access_token"].is_string());
    assert!(login["refresh_token"].is_string());

    {{#if has_organizations}}
    let access_token = login["access_token"].as_str().expect("access token");
    let (status, organizations) = request_with_token(
        &app,
        Method::GET, "/organizations",
        Value::Null,
        Some(access_token),
    )
    .await;
    assert_eq!(status, StatusCode::OK, "organizations response: {organizations}");
    {{/if}}
}

