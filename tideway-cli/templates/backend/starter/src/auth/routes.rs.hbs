pub(crate) fn auth_openapi(allow_public_registration: bool) -> utoipa::openapi::OpenApi {
    let mut document = <AuthApiDoc as utoipa::OpenApi>::openapi();
    if !allow_public_registration {
        document.paths.paths.remove("/auth/register");
    }
    document
}
